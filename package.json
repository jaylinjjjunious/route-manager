{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "vite build --config vite.config.standalone.ts && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:habits": "node tests/habit-ui-check.cjs",
    "verify": "node scripts/verify.cjs",
    "checkpoint": "node scripts/checkpoint.cjs",
    "release": "node scripts/release.cjs"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/vite": "^4.1.14",
    "@types/google.maps": "^3.65.2",
    "@vis.gl/react-google-maps": "^1.9.0",
    "@vitejs/plugin-react": "6.0.2",
    "@zxing/browser": "^0.1.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-server-dom-webpack": "19.2.7",
    "vinext": "0.0.50",
    "vite": "8.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "0.5.26",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.28.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "wrangler": "4.92.0"
  }
}
